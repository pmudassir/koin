{
  "expo": {
    "name": "Koin",
    "slug": "koin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F4FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mudassirmhd.koin",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "koin"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F4FF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.mudassirmhd.koin"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "08d86ddd-ce27-4c89-a8a6-6d817604836e"
      }
    },
    "owner": "mudassirmhd",
    "plugins": [
      "expo-sharing",
      ["expo-widgets", {
        "widgets": [
          {
            "name": "BudgetWidget",
            "src": "./widgets/BudgetWidget.tsx",
            "families": ["systemSmall", "systemMedium"],
            "description": "See today's spending and budget at a glance"
          },
          {
            "name": "QuickAddWidget",
            "src": "./widgets/QuickAddWidget.tsx",
            "families": ["accessoryCircular"],
            "description": "Quick add expense"
          }
        ]
      }]
    ]
  }
}
